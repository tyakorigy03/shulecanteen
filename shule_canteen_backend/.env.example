# ================================================================
# shule_canteen_backend/.env
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ================================================================

PORT=5000
NODE_ENV=production

# JWT secret — generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_string

# Firebase Admin SDK — path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# MTN MoMo (leave empty until you have real credentials)
MTN_MOMO_BASE_URL=https://proxy.momoapi.mtn.co.rw
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENVIRONMENT=mtnrwanda
MTN_MOMO_CURRENCY=RWF
